# Hugo build output
public/
resources/_gen/

# Pagefind (generated during build)
# public/pagefind/ is already covered by public/

# Node.js
node_modules/
npm-debug.log*

# Python
__pycache__/
*.py[cod]
*.pyo
.env
.venv
venv/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs (keep directory, ignore content)
logs/*.jsonl
data/logs/*.log
data/logs/*.jsonl

# Data files (keep directories via .gitkeep, ignore generated data)
data/trends/*.json
data/ugc/*.json
data/threads/*.json
data/packages/*.json
data/metrics/*.json

# Hugo temp
.hugo_build.lock
